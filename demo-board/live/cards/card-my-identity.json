{
  "id": "card-my-identity",
  "meta": {
    "title": "My Identity",
    "tags": [
      "m365",
      "workiq"
    ],
    "desc": "Displays your M365 display name via WorkIQ (Microsoft 365 Copilot)."
  },
  "source_defs": [
    {
      "bindTo": "identity",
      "outputFile": "card-my-identity.txt",
      "workiq": {
        "query_template": "what is my full display name. No Fluff. No Commentary. No Descriptions. Just Answer the Question"
      }
    },
    {
      "bindTo": "manager",
      "outputFile": "card-my-identity-manager.txt",
      "workiq": {
        "query_template": "who is my manager. No Fluff. No Commentary. No Descriptions. Just Answer with the name"
      }
    }
  ],
  "view": {
    "elements": [
      {
        "kind": "markdown",
        "data": {
          "bind": "fetched_sources.identity"
        }
      },
      {
        "kind": "markdown",
        "data": {
          "template": "**Manager:** {{fetched_sources.manager}}"
        }
      }
    ],
    "layout": {
      "board": {
        "col": 4,
        "order": 10
      },
      "canvas": {
        "x": 50,
        "y": 450,
        "w": 420,
        "h": 260
      }
    },
    "features": {
      "refresh": true
    }
  },
  "card_data": {}
}