{
  "name": "demo-boards",
  "version": "1.0.0",
  "type": "module",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "node scripts/start-server.cjs demo-board --all",
    "backend": "node scripts/start-server.cjs demo-board --backend",
    "frontend": "npx http-server demo-board -p 8000 -c-1",
    "clean": "node -e \"const fs=require('fs'),p=require('path'),d=p.join(__dirname,'demo-board','live');if(fs.existsSync(d)){for(const e of fs.readdirSync(d,{withFileTypes:true})){if(['cards','gandalf-cards'].includes(e.name))continue;fs.rmSync(p.join(d,e.name),{recursive:true,force:true});console.log('removed',e.name)}}console.log('clean done')\"",
    "stop": "node -e \"const {execSync}=require('child_process');['7799','8000'].forEach(p=>{try{execSync('npx kill-port '+p,{stdio:'ignore'})}catch{}});console.log('stopped ports 7799 and 8000')\""
  },
  "keywords": [],
