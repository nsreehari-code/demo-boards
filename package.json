{
  "name": "demo-boards",
  "version": "1.0.0",
  "type": "module",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "node scripts/start-server.cjs demo-board --all",
    "backend": "node scripts/start-server.cjs demo-board --backend",
    "frontend": "npx http-server demo-board -p 8000 -c-1",
    "seed-cpm": "node demo-board/scripts/sqlite/seed-cpm.cjs",
    "clean": "node -e \"const fs=require('fs'),p=require('path');['live','cpm'].forEach(sub=>{const d=p.join(__dirname,'demo-board',sub);if(fs.existsSync(d)){for(const e of fs.readdirSync(d,{withFileTypes:true})){if(['cards','gandalf-cards','.gitignore','.retain'].includes(e.name))continue;fs.rmSync(p.join(d,e.name),{recursive:true,force:true});console.log('removed',sub+'/'+e.name)}}});console.log('clean done')\"",
    "stop": "node -e \"const {execSync}=require('child_process');['7799','8000'].forEach(p=>{try{execSync('npx kill-port '+p,{stdio:'ignore'})}catch{}});console.log('stopped ports 7799 and 8000')\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "yaml-flow": "^5.4.2"
  },
  "devDependencies": {
    "http-server": "^14.1.1"
  }
}
